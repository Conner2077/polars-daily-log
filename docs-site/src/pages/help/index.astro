  .nav-center { display: flex; align-items: center; gap: 32px; font-size: 15px; }
  .nav-center a { color: var(--ink-muted); font-weight: 400; }
  .nav-center a.active { color: var(--ink); font-weight: 500; }
  .nav-center a:hover { color: var(--ink); opacity: 1; }
