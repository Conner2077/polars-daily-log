  .content h4 { font-size: 16px; font-weight: 600; margin: 24px 0 10px; color: var(--ink); }
  .content p { margin: 14px 0; font-size: 16px; }
  .content ul, .content ol { margin: 14px 0; padding-left: 22px; }
